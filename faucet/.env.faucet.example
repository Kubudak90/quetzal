# Quetzal Faucet — environment template
# Copy to .env.faucet (gitignored) and fill in secrets before running.

# Server
FAUCET_PORT=3030
FAUCET_NODE_ENV=production

# L1 — Sepolia (Aztec testnet's L1)
FAUCET_L1_RPC_URL=https://sepolia.drpc.org
FAUCET_L1_PK=
# Optional — informational ops echo. The bridge auto-discovers this from
# node.getNodeInfo().l1ContractAddresses.feeJuicePortalAddress at runtime.
# Set this if you want to assert at startup that the L2 node points where
# you expect (useful for catching env/network mismatches in staging).
FAUCET_L1_FEE_JUICE_PORTAL=

# L1 chain ID — used to configure viem's Sepolia client.
#   Sepolia (default): 11155111
#   Anvil local:       31337
FAUCET_L1_CHAIN_ID=11155111

# L2 — Aztec testnet
FAUCET_L2_NODE_URL=https://rpc.testnet.aztec-labs.com
FAUCET_L2_SECRET=
# Optional. Required ONLY when recreating a pre-deployed operator account whose
# deploy used an explicit random signing key (e.g. the m3-era admin 0x0524b493…,
# whose key is persisted in testnet-m1-state.json). Without it, createSchnorrAccount
# derives a fresh key → different L2 address → admin's balances invisible to faucet.
FAUCET_L2_SIGNING_KEY=
# Optional. Defaults to Fr.ZERO. Set only if the account was deployed with a
# non-zero salt.
FAUCET_L2_SALT=
FAUCET_L2_TUSDC=0x09075988b52dec9c83c7da73ca3f746c14431a7974ccd8fb899e6476ef6b6b22
FAUCET_L2_TETH=0x1c839479228a2cf9304a61ea4d0b3b2d3c319f3e72c8f4d87c3ade3a5809a198

# Per-drip amounts (atomic)
FAUCET_FEE_JUICE_AMOUNT=100000000000000000000
FAUCET_TUSDC_AMOUNT=1000000000
FAUCET_TETH_AMOUNT=500000000000000000

# Abuse
HCAPTCHA_SECRET_KEY=
FAUCET_HCAPTCHA_BYPASS_KEY=
FAUCET_GLOBAL_DAILY_CAP=500
# Per-IP rate limit: up to FAUCET_PER_IP_MAX_DRIPS_PER_WINDOW hits per FAUCET_PER_IP_WINDOW_SECONDS.
# Sub-7b's onboarding wizard fires N=3 parallel drips from one IP, so default
# 4 hits per 8h covers N=3 + 1 retry buffer.
FAUCET_PER_IP_MAX_DRIPS_PER_WINDOW=4
FAUCET_PER_IP_WINDOW_SECONDS=28800

# CORS — comma-separated; supports plain origins + /regex/ entries
FAUCET_ALLOWED_ORIGINS=https://quetzaldex.xyz,https://www.quetzaldex.xyz,https://aztec-project.vercel.app,/^https:\/\/.*-kubudak90s-projects\.vercel\.app$/

# Drain threshold — service returns 503 when balance < 10 * per-drip amount
FAUCET_DRAIN_THRESHOLD_MULTIPLIER=10

# Storage
FAUCET_SQLITE_PATH=./data/faucet.sqlite
FAUCET_AUDIT_LOG_PATH=./data/faucet.log
