# Sub-8.1 aggregator — VPS deploy env template.
#
# Copy to .env.aggregator on the VPS and fill in.  Values shown here are the
# production testnet defaults from quetzal.config.json.  AGGREGATOR_L2_SECRET
# must be regenerated per-deploy (never reuse another wallet's secret).

# ── HTTP server ────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── L2 (Aztec testnet) ─────────────────────────────────────────────────────
AZTEC_NODE_URL=https://rpc.testnet.aztec-labs.com

# Quetzal protocol contracts (from quetzal.config.json).
# Addresses below are pre-Sub-9 era; updated values come from the latest
# redeploy state files. VPS .env.aggregator is set per-deploy.
ORDERBOOK_ADDRESS=0x2486ac705f0e7b509256dc96c8310a3abdf6465faa4a24e406a10fbcc17e5184
# Sub-9.3: per-pool addresses for the multi-pair clearing loop.
# POOL_ADDRESS (legacy single) remains a synonym for POOL_USDC_ETH_ADDRESS.
POOL_USDC_ETH_ADDRESS=
POOL_USDC_BTC_ADDRESS=
POOL_ETH_BTC_ADDRESS=
POOL_ADDRESS=0x1c06506878d782e8060557bc0ac73a4ff38cfda00083035103058b73be2def75
TREASURY_ADDRESS=0x1b2c36d0b7f5da9ccb7888eee7785111f4a5c35778097bb79957ac031a6606e6
AGGREGATOR_REGISTRY_ADDRESS=0x00e43e816cdc85de14b31c02450b06890f0ebca5c19023d2fdb511fd16ece8e0
TUSDC_ADDRESS=0x09075988b52dec9c83c7da73ca3f746c14431a7974ccd8fb899e6476ef6b6b22
TETH_ADDRESS=0x1c839479228a2cf9304a61ea4d0b3b2d3c319f3e72c8f4d87c3ade3a5809a198
TBTC_ADDRESS=
ADMIN_ADDRESS=0x0524b493a6766243d07f655a26ceb5e71c44af9cf0060c670f49ee7699c92a00

# ── Sub-9.3 clearing-cycle gate ───────────────────────────────────────────
# Set CLEARING_ENABLED=1 to wire the full multi-pair close_epoch_and_clear_verified
# submit path. Requires nargo + bb in $PATH (the runtime image bakes them in)
# AND an AGGREGATOR_L2_SECRET pointing at a FUNDED wallet (admin's secret is
# fine for MVP; ~10-20 FJ per clearing tx). Leaving unset keeps the legacy
# Sub-8.1 log-only behavior.
# CLEARING_ENABLED=1

# Override snapshots dir (default: /repo/aggregator/data/snapshots).
# SNAPSHOTS_DIR=/repo/aggregator/data/snapshots

# Ephemeral wallet secret for the read-only epoch watcher.  Must fit in the
# BN254 Fr field (< 2^254 + 1).  Naive `openssl rand -hex 32` overflows ~35%
# of the time.  Use the rejection-sample workaround — force a zero high byte:
#   openssl rand -hex 31 | sed 's/^/00/'
# In the MVP this wallet only does simulate() calls so it does NOT need
# fee-juice or any L2 funding.  When Sub-8.1.next wires close_epoch_and_clear_verified
# this MUST be replaced with a funded wallet bootstrapped via the faucet.
AGGREGATOR_L2_SECRET=0xREPLACE_ME_RUN_openssl_rand_hex_31_with_00_prefix

# Override for the SDK's contracts-binding dir.  Container WORKDIR is
# /repo/aggregator so the SDK's default `cwd/tests/integration/generated`
# resolves wrong; pin to the absolute path.
QUETZAL_CONTRACTS_DIR=/repo/tests/integration/generated

# Epoch watcher poll cadence (ms).  Testnet epochs are ~tens of seconds so
# polling every 15s is plenty; tune lower for sandbox or higher to save load.
WATCHER_INTERVAL_MS=15000

# ── Sub-5c relayer side-loop (optional) ───────────────────────────────────
# Set RELAYER_MODE=1 to start the Treasury bridge-claim relayer loop on top
# of the reveal server.  Requires an L1 RPC + funded L1 EOA.  Leave commented
# out for the MVP — Sub-5c relayer can be enabled later without re-deploying.
# RELAYER_MODE=1
# L1_RPC_URL=https://sepolia.infura.io/v3/...
# L1_PRIVATE_KEY=0x...
